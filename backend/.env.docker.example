# Copy to `.env` when running the API on the host against Docker Postgres:
#   docker compose up postgres migrate -d
#   cp .env.docker.example .env
#   npm run start:dev

PORT=3000
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/frontera
DATABASE_SSL=false

# Supabase Auth — copy from your main .env if not already set
# SUPABASE_URL=https://your-project.supabase.co
# AUTH_DISABLED=false

FRONTERA_AWS_REGION=us-east-1
DOCUMENTS_BUCKET=frontera-dev-secure-documents
EXPORTS_BUCKET=frontera-dev-exports
SES_FROM_EMAIL=scheduling@yourdomain.com

# Invite email links + Swagger Try-it-out (local API on host port 3000)
FRONTERA_API_PUBLIC_URL=http://localhost:3000
FRONTERA_APP_URL=http://localhost:5173
