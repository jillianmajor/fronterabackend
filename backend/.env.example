# =============================================================================
# Frontera Scheduling API — environment variables
# Copy to `.env` and fill in values. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Local API (npm run start:dev)
# -----------------------------------------------------------------------------

# HTTP port for Nest (default 3000)
PORT=3000

# development | production (optional locally; Lambda sets production via serverless)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database (required)
# Used by: Nest RepositoryModule, drizzle-kit (db:generate, db:migrate, db:push, db:studio)
# -----------------------------------------------------------------------------

# Supabase Postgres — direct connection or connection pooler (recommended for Lambda)
# Example pooler: postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Example direct:  postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Docker local:    postgresql://postgres:postgres@127.0.0.1:5432/frontera  (see docker compose / .env.docker.example)
DATABASE_URL=

# Auto: SSL off for localhost / Docker hostname `postgres`. Set false explicitly for Docker-from-host.
# DATABASE_SSL=false

# -----------------------------------------------------------------------------
# Supabase Auth (Q1 — JWT guard; optional until auth ships)
# Used by: serverless deploy (provider.environment); future auth module
# -----------------------------------------------------------------------------

# Project URL — https://[PROJECT].supabase.co
# Required for JWT auth: JWKS is derived as {SUPABASE_URL}/auth/v1/.well-known/jwks.json
SUPABASE_URL=

# Optional HS256 fallback (legacy). Frontera uses JWKS from SUPABASE_URL — leave unset.
# SUPABASE_JWT_SECRET=

# Set true to skip JWT guards (Swagger-only local testing). Default: auth enforced when SUPABASE_URL is set.
AUTH_DISABLED=false

# Optional override when JWKS is not at the default path under SUPABASE_URL
# SUPABASE_JWKS_URL=https://[PROJECT].supabase.co/auth/v1/.well-known/jwks.json

# Service role key — required for accept-invite password activation (Admin API). Never expose to the browser.
# Required for accept-invite password setup on hosted Supabase (Admin API).
# Without it, accept-invite falls back to SQL crypt (works locally; Admin API is preferred in prod).
# SUPABASE_SERVICE_ROLE_KEY=

# Dev portal logins (after db:seed): npm run db:seed:dev-logins
# admin@fronterasearch.com / TestAdmin123!  — admin role, corporate + provider switcher
# prn.demo@fronterasearch.com / PrnDemo123!  — PRN provider portal

# -----------------------------------------------------------------------------
# AWS — credentials (local dev & CLI)
# Prefer AWS_PROFILE over access keys. Required for: serverless deploy, future S3/SES/SQS usage
# -----------------------------------------------------------------------------

# Region for deploy and SDK clients (must match serverless provider.region).
# Not AWS_REGION — that name is reserved on Lambda.
FRONTERA_AWS_REGION=us-east-1

# Named profile from ~/.aws/credentials (recommended)
# AWS_PROFILE=your-profile

# Or explicit keys (avoid in shared machines; use profile when possible)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional session token for temporary credentials
# AWS_SESSION_TOKEN=

# -----------------------------------------------------------------------------
# AWS — resources (Lambda + future repository/aws)
# serverless.yml sets these on deploy; mirror names here for local work against dev stack
# Bucket pattern: frontera-{stage}-secure-documents / frontera-{stage}-exports
# -----------------------------------------------------------------------------

# PACR and other secure uploads (Q2+)
DOCUMENTS_BUCKET=frontera-dev-secure-documents

# Master calendar / export artifacts (Q4+)
EXPORTS_BUCKET=frontera-dev-exports

# -----------------------------------------------------------------------------
# Serverless deploy (optional — CLI flags override)
# -----------------------------------------------------------------------------

# Stage passed to serverless deploy (default dev in serverless.yml)
# SLS_STAGE=dev

# -----------------------------------------------------------------------------
# SES (deploy via serverless.yml — invite, liaison PACR, notifications)
# -----------------------------------------------------------------------------

# Verified sender; must match FRONTERA_AWS_REGION. Created as AWS::SES::EmailIdentity on deploy when set.
SES_FROM_EMAIL=notifications@fronteraportal.com

# Optional override; serverless sets frontera-{stage}-scheduling on Lambda
# SES_CONFIGURATION_SET=frontera-dev-scheduling

# Provider portal login URL — redirect after accept-invite password setup.
# MUST point at a frontend whose VITE_SUPABASE_* matches this backend's DATABASE_URL / SUPABASE_URL.
# Local Vite (port 8080): http://localhost:8080/login?portal=provider
# Do NOT use the old Lovable preview URL unless that app uses the same Supabase project.
FRONTERA_APP_URL=http://localhost:8080/login?portal=provider

# Public API URL — invite email links (GET/POST /accept-invite on Nest)
# Local Docker / start:dev: http://localhost:3000 (also auto-fallback when NODE_ENV !== production)
# Deployed Lambda: your API Gateway URL (serverless sets this on deploy)
# Deployed API base URL (no trailing slash). Defaults to https://api.fronteraportal.com via serverless.yml if unset.
FRONTERA_API_PUBLIC_URL=https://api.fronteraportal.com

# -----------------------------------------------------------------------------
# Async work (future — enqueue → 202 → consumer Lambda; not wired yet)
# -----------------------------------------------------------------------------

# SQS_QUEUE_URL=

# -----------------------------------------------------------------------------
# Seed data (npm run db:seed — deterministic UUIDs in scripts/seed/ids.ts)
# -----------------------------------------------------------------------------

# Optional — printed after db:seed for future auth/integration tests
# FRONTERA_SEED_RECRUITER_USER_ID=a0000000-0000-4000-8000-000000000001
# FRONTERA_SEED_PROVIDER_USER_ID=a0000000-0000-4000-8000-000000000002

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------

# e2e tests default DATABASE_URL if unset (see test/app.e2e-spec.ts)
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/postgres
